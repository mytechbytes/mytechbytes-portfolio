{
  // Cloudflare Workers deployment config for the static portfolio.
  // The @astrojs/cloudflare adapter emits prerendered assets into ./dist/client
  // (./dist/server stays empty while the site is fully static). No `main` worker
  // entry is needed until a route opts into on-demand rendering.
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "vivek-kumar-portfolio",
  "compatibility_date": "2026-06-24",
  "assets": {
    "directory": "./dist/client"
  }
}
